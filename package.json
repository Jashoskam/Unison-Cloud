{
  "name": "unison-agentic-os",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build:clean": "rm -rf dist && mkdir -p dist/assets",
    "build:copy": "cp -r public/* dist/ 2>/dev/null || true",
    "build:assets": "mkdir -p dist/src/assets && cp -r src/assets/* dist/src/assets/ 2>/dev/null || true",
    "build:css": "npx @tailwindcss/cli -i src/index.css -o dist/assets/index.css --minify",
    "build:js": "npx esbuild src/main.tsx --bundle --minify --sourcemap --outfile=dist/assets/index.js --format=esm --loader:.png=file --loader:.svg=file --loader:.jpg=file --loader:.webp=file --loader:.mp3=file --loader:.woff=file --loader:.woff2=file --loader:.ttf=file --external:*.css --define:process.env.NODE_ENV=\\\"production\\\" --define:process.env.GEMINI_API_KEY=\\\"\\\"",
    "build:html": "node -e \"const fs=require('fs'); let h=fs.readFileSync('index.html','utf8'); const idx=h.indexOf('</head>'); if(idx!==-1) h=h.slice(0,idx)+'\\n    <link rel=\\\"stylesheet\\\" href=\\\"/assets/index.css\\\" />\\n'+h.slice(idx); h=h.replace('/src/main.tsx','/assets/index.js'); fs.writeFileSync('dist/index.html',h);\"",
    "build:server": "npx esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build": "npm run build:clean && npm run build:copy && npm run build:assets && npm run build:css && npm run build:js && npm run build:html && npm run build:server",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist",
    "lint": "eslint src --quiet",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@google/generative-ai": "^0.24.1",
    "@monaco-editor/react": "^4.7.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/three": "^0.184.1",
    "@types/ws": "^8.18.1",
    "@vis.gl/react-google-maps": "^1.8.3",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "esbuild": "^0.28.0",
    "express": "^4.21.2",
    "firebase": "^12.13.0",
    "firebase-admin": "^14.0.0",
    "highlight.js": "^11.11.1",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pptxgenjs": "^4.0.1",
    "prettier": "^3.8.5",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.14",
    "three": "^0.184.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "ws": "^8.20.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/jszip": "^3.4.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "vitest": "^4.1.9"
  }
}
